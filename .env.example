# ─────────────────────────────────────────────────────────────────
# Flatifigo — Environment Variables
# Copy this file to .env and fill in your values before running
# locally. Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────
# Generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Hours before a JWT token expires (default: 24)
JWT_EXPIRY_HOURS=24

# ── Database ──────────────────────────────────────────────────────
# SQLite (local dev, default):
# DATABASE_URL=sqlite:///flatifigo.db
#
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///flatifigo.db

# ── Server ────────────────────────────────────────────────────────
PORT=5000

# Set to "true" only for local development — NEVER in production
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated allowed origins, or "*" to allow all.
# Example: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*

# ── Storage ───────────────────────────────────────────────────────
# Absolute or relative path to the uploads directory
UPLOAD_FOLDER=uploads

# Maximum file upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216
