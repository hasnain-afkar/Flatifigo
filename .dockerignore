# Git
.git
.gitignore

# Python caches
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Local environment file — never copy secrets into the image
.env

# Database (mounted as a volume at runtime)
*.db
*.sqlite
*.sqlite3

# Uploads (mounted as a volume at runtime)
uploads/

# Editor / OS artefacts
.DS_Store
Thumbs.db
.idea/
.vscode/

# Documentation / reports (not needed in the image)
*.pdf
*.docx
README.md
